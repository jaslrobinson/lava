{
  "productName": "KLLW",
  "version": "0.1.0",
  "identifier": "com.kllw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cargo build -p klwp-wallpaper && pnpm dev",
    "beforeBuildCommand": "cargo build -p klwp-wallpaper --release && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Kustom Linux Live Wallpaper",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "KLLW - Kustom Linux Live Wallpaper"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http:; img-src 'self' asset: https://asset.localhost http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {}
}
