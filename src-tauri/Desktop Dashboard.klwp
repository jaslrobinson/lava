          "properties": {
            "x": 0.0,
            "y": 275.0,
            "width": 80.0,
            "height": 3.0,
            "shapeKind": "rectangle",
            "fill": "#4a9eff",
            "cornerRadius": 2.0
          },
          "visible": true
        },
        {
          "id": "clock_day",
