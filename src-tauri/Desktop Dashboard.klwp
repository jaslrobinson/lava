    {
      "id": "clock_group",
      "name": "Clock",
      "type": "overlap",
      "properties": {
        "x": 120.0,
        "y": 320.0,
        "width": 800.0,
        "height": 500.0
      },
      "children": [
        {
          "id": "clock_time",
          "name": "Time",
          "type": "text",
          "properties": {
            "x": 0.0,
            "y": 0.0,
            "width": 700.0,
            "height": 220.0,
            "opacity": 255.0,
            "text": "$df(HH:mm)$",
            "fontSize": 180.0,
            "fontFamily": "sans-serif",
            "color": "#ffffff",
            "textAlign": "left",
            "shadow": {
              "color": "#00000060",
              "dx": 2.0,
              "dy": 4.0,
              "radius": 10.0
            }
          },
          "visible": true
        },
        {
          "id": "clock_seconds",
          "name": "Seconds",
          "type": "text",
          "properties": {
            "x": 0.0,
            "y": 200.0,
            "width": 200.0,
            "height": 60.0,
            "text": "$df(ss)$",
            "fontSize": 48.0,
            "fontFamily": "sans-serif",
            "color": "#ffffff40",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "clock_divider",
