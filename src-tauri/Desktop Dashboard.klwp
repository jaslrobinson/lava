          "type": "text",
          "properties": {
            "x": 0.0,
            "y": 295.0,
            "width": 700.0,
            "height": 50.0,
            "text": "$df(EEEE)$",
            "fontSize": 36.0,
            "fontFamily": "sans-serif",
            "color": "#4a9eff",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "clock_date",
