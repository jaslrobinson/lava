{
  "version": "0.1.0",
  "name": "Desktop Dashboard",
  "resolution": { "width": 2048, "height": 1280 },
  "background": { "type": "color", "value": "#0b0e17" },
  "globals": [
    { "name": "weather_temp", "type": "text", "value": "72°F" },
    { "name": "weather_condition", "type": "text", "value": "Partly Cloudy" },
    { "name": "weather_hi", "type": "text", "value": "78°" },
    { "name": "weather_lo", "type": "text", "value": "61°" },
    { "name": "music_title", "type": "text", "value": "Midnight City" },
    { "name": "music_artist", "type": "text", "value": "M83" },
    { "name": "music_album", "type": "text", "value": "Hurry Up, We're Dreaming" },
    { "name": "music_progress", "type": "number", "value": 35 },
    { "name": "news_1", "type": "text", "value": "Technology sector sees record growth in Q1 2026" },
    { "name": "news_2", "type": "text", "value": "New open-source AI models challenge proprietary alternatives" },
    { "name": "news_3", "type": "text", "value": "Linux desktop market share reaches new milestone" },
    { "name": "news_source", "type": "text", "value": "Tech News" }
  ],
  "layers": [
    {
      "id": "bg_gradient_top",
      "name": "Gradient Top",
      "type": "shape",
      "properties": {
        "x": 0, "y": 0,
        "width": 2048, "height": 400,
        "shapeKind": "rectangle",
        "fill": "#0b0e1780",
        "opacity": 200
      },
      "visible": true
    },
    {
      "id": "bg_gradient_bottom",
      "name": "Gradient Bottom",
      "type": "shape",
      "properties": {
        "x": 0, "y": 980,
        "width": 2048, "height": 300,
        "shapeKind": "rectangle",
        "fill": "#00000090",
        "opacity": 200
      },
      "visible": true
    },

    {
      "id": "clock_group",
      "name": "Clock",
      "type": "overlap",
      "properties": {
        "x": 120, "y": 320,
        "width": 800, "height": 500
      },
      "visible": true,
      "children": [
        {
          "id": "clock_time",
          "name": "Time",
          "type": "text",
          "properties": {
            "x": 0, "y": 0,
            "width": 700, "height": 220,
            "text": "$df(HH:mm)$",
            "fontSize": 180,
            "fontFamily": "sans-serif",
            "color": "#ffffff",
            "textAlign": "left",
            "opacity": 255,
            "shadow": { "color": "#00000060", "dx": 2, "dy": 4, "radius": 10 }
          },
          "visible": true
        },
        {
          "id": "clock_seconds",
          "name": "Seconds",
          "type": "text",
          "properties": {
            "x": 0, "y": 200,
            "width": 200, "height": 60,
            "text": "$df(ss)$",
            "fontSize": 48,
            "fontFamily": "sans-serif",
            "color": "#ffffff40",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "clock_divider",
          "name": "Divider",
          "type": "shape",
          "properties": {
            "x": 0, "y": 275,
            "width": 80, "height": 3,
            "shapeKind": "rectangle",
            "fill": "#4a9eff",
            "cornerRadius": 2
          },
          "visible": true
        },
        {
          "id": "clock_day",
          "name": "Day of Week",
          "type": "text",
          "properties": {
            "x": 0, "y": 295,
            "width": 700, "height": 50,
            "text": "$df(EEEE)$",
            "fontSize": 36,
            "fontFamily": "sans-serif",
            "color": "#4a9eff",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "clock_date",
          "name": "Date",
          "type": "text",
          "properties": {
            "x": 0, "y": 345,
            "width": 700, "height": 45,
            "text": "$df(MMMM d, yyyy)$",
            "fontSize": 28,
            "fontFamily": "sans-serif",
            "color": "#ffffff80",
            "textAlign": "left"
          },
          "visible": true
        }
      ]
    },

    {
      "id": "weather_group",
      "name": "Weather",
      "type": "overlap",
      "properties": {
        "x": 1500, "y": 80,
        "width": 460, "height": 280
      },
      "visible": true,
      "children": [
        {
          "id": "weather_bg",
          "name": "Weather BG",
          "type": "shape",
          "properties": {
            "x": 0, "y": 0,
            "width": 460, "height": 280,
            "shapeKind": "rectangle",
            "fill": "#ffffff08",
            "cornerRadius": 20,
            "stroke": "#ffffff10",
            "strokeWidth": 1
          },
          "visible": true
