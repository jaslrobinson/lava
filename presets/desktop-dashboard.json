        {
          "id": "weather_temp_text",
          "name": "Temperature",
          "type": "text",
          "properties": {
            "x": 30, "y": 30,
            "width": 300, "height": 100,
            "text": "$gv(weather_temp)$",
            "fontSize": 72,
            "fontFamily": "sans-serif",
            "color": "#ffffff",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "weather_condition_text",
          "name": "Condition",
          "type": "text",
          "properties": {
            "x": 30, "y": 130,
            "width": 400, "height": 40,
            "text": "$gv(weather_condition)$",
            "fontSize": 24,
            "fontFamily": "sans-serif",
            "color": "#ffffff90",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "weather_hilo",
          "name": "Hi / Lo",
          "type": "text",
          "properties": {
            "x": 30, "y": 180,
            "width": 400, "height": 30,
            "text": "H: $gv(weather_hi)$  L: $gv(weather_lo)$",
            "fontSize": 18,
            "fontFamily": "sans-serif",
            "color": "#ffffff50",
            "textAlign": "left"
          },
          "visible": true
        },
        {
          "id": "weather_label",
          "name": "Weather Label",
          "type": "text",
          "properties": {
            "x": 30, "y": 230,
            "width": 400, "height": 25,
            "text": "WEATHER",
            "fontSize": 11,
            "fontFamily": "sans-serif",
            "color": "#4a9eff60",
            "textAlign": "left"
          },
          "visible": true
        }
      ]
    },

